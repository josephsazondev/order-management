# Which backend the frontend talks to:
#   mock       -> in-browser mock adapter (localStorage), runs with no deployment
#   appsscript -> live Google Apps Script web app (set VITE_APPSCRIPT_URL below)
VITE_API_MODE=mock

# Which mock dataset to seed (only used when VITE_API_MODE=mock):
#   full   -> full demo dataset: subscriptions, payments, invoices, audit (default)
#   empty  -> clean slate: only users/roles/settings/products, zero transactional data
# Shortcut: `npm run dev:empty` sets this for you.
VITE_MOCK_SEED=full

# Deployed Apps Script web-app URL (only used when VITE_API_MODE=appsscript)
# e.g. https://script.google.com/macros/s/AKfycb.../exec
VITE_APPSCRIPT_URL=

# Base path for GitHub Pages builds, e.g. /order-management/
# Leave unset for local dev.
# VITE_BASE=/order-management/
